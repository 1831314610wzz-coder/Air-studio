# Vercel environment variables template
# Copy each item below into:
# Vercel -> Project Settings -> Environment Variables
#
# Do not commit a real .env.vercel file with live API keys.

# --------------------------------------
# Text model / LLM (default: ARK)
# --------------------------------------
VITE_CUSTOM_TEXT_API_KEY=6d9ad2a4-2559-49cc-ae07-6f48923dd946
VITE_CUSTOM_TEXT_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VITE_CUSTOM_TEXT_API_NAME=ark-llm
VITE_CUSTOM_TEXT_MODELS=doubao-1-5-pro-32k-250115
VITE_CUSTOM_DEFAULT_TEXT_MODEL=doubao-1-5-pro-32k-250115

# --------------------------------------
# Image generation (default: APIYI)
# --------------------------------------
VITE_CUSTOM_IMAGE_API_KEY=sk-hX4dlo2FtrwFsp2c3558Fa7036Ce49C6A155F25019C483F7
VITE_CUSTOM_IMAGE_API_BASE_URL=https://api.apiyi.com/v1
VITE_CUSTOM_IMAGE_API_NAME=apiyi-image
VITE_CUSTOM_IMAGE_MODELS=nano-banana,nano-banana-2,nano-banana-pro
VITE_CUSTOM_DEFAULT_IMAGE_MODEL=nano-banana

# --------------------------------------
# Generic custom fallback
# Recommended to keep aligned with image provider
# --------------------------------------
VITE_CUSTOM_API_KEY=YOUR_APIYI_IMAGE_API_KEY
VITE_CUSTOM_API_BASE_URL=https://api.apiyi.com/v1
VITE_CUSTOM_API_NAME=apiyi

# --------------------------------------
# Optional Google / Gemini fallback
# Only set if you still want Gemini-related paths available
# --------------------------------------
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# --------------------------------------
# ARK image size whitelist
# Safe to keep even if image generation is not using ARK by default
# --------------------------------------
VITE_ARK_IMAGE_ALLOWED_SIZES=2048x2048,2560x1440,1440x2560,2304x1536,1536x2304,2K

# --------------------------------------
# Optional feature flags
# --------------------------------------
VITE_ENABLE_AI=true
VITE_ENABLE_VIDEO=true
VITE_ENABLE_INSPIRATION=true
VITE_LOG_LEVEL=info
VITE_ENABLE_ANALYTICS=false

# --------------------------------------
# Internal access auth for Vercel
# Set either AIRSTUDIO_AUTH_USERS or the single user pair below.
# Examples:
# AIRSTUDIO_AUTH_USERS=alice:pass123,bob:pass456
# --------------------------------------
AIRSTUDIO_AUTH_USERS=
AIRSTUDIO_AUTH_USERNAME=internal
AIRSTUDIO_AUTH_PASSWORD=CHANGE_THIS_PASSWORD
AIRSTUDIO_AUTH_SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
